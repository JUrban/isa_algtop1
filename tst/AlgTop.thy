        \<comment> \<open>?f is a loop: \<Phi>\_w(\<eta>\_w \<alpha>) is in \<pi>\_1(A,a), so its representative is a loop.\<close>
        have heta_in: "\<eta>_w \<alpha> \<in> F_w"
