        also have "\<dots> = qC (edge_pt (i_of \<alpha>) t)" using hfact \<open>t \<in> I_set\<close> by (by100 blast)
        also have "\<dots> = qC ((1-t) * vxC (i_of \<alpha>) + t * vxC (Suc (i_of \<alpha>) mod ?n),
