    \<comment> \<open>Apply wrapper: finite\_wedge\_pi1\_free\_with\_chosen\_loops\_arb.\<close>
    have hC_data: "\<forall>\<alpha>\<in>?J. C \<alpha> \<subseteq> A \<and> a \<in> C \<alpha>"
