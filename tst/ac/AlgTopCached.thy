        \<comment> \<open>pp(first_h, second_h) agrees with piece∘ψ on I_set, hence homotopic.\<close>
        have hpp_eq_piece_psi: "\<And>t. t \<in> I_set \<Longrightarrow>
            top1_path_product first_h second_h t = piece
