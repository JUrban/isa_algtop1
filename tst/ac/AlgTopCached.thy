                have "0 \<le> p - s k" using hpL by (by100 linarith)
                have "0 \<le> 2 * t * (p - s k)" using \<open>0 \<le> t\<close> \<open>0 \<le> p - s k\<close> by (by100 simp)
                moreover have "2 * t * (p - s k) \<le> s (Suc k) - s k"
