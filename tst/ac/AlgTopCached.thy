                  hence "2 * t * (p - s k) \<le> p - s k" by (by100 simp)
                  thus ?thesis using hpR by (by100 linarith)
                qed
                ultimately show ?thesis using hd_pos by (by100 simp)
              qed
              ultimately show ?thesis unfolding top1_unit_interval_def by (by100 simp)
            next
