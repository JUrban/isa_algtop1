              have hF1': "\<forall>s\<in>I_set. F (s, 1) = piece_V 0 sub' s"
                using hF1 hmerged_eq_V by (by100 force)
              have hpp_V: "top1_is_path_on V (subspace_topology X TX V) (g (sub 0)) (g (sub (Suc (Suc 0))))
